#!/bin/bash
# ============================================================
# 多USV协同运输调度 — 一键启动脚本
# 自动读取 config/usvs.txt 和 config/tasks.txt，规模自适应
# 对比: Greedy vs Graph-ALNS (公平约束适配)
# ============================================================
set -e
cd /root/demon3.16
PY=/usr/bin/python3
$PY -m pip install numpy matplotlib Pillow pyyaml -q 2>/dev/null

# ── 读取配置规模 ──
N_SHIPS=$(grep -c '^USV:' src/task_planner/config/usvs.txt 2>/dev/null || echo 0)
N_TASKS=$(grep -c '^Task' src/task_planner/config/tasks.txt 2>/dev/null || echo 0)
echo "配置: ${N_SHIPS}艘船 × ${N_TASKS}个任务"
echo ""

# ============================================================
#  1/3 生成路网 (C++ roadmap_generator)
# ============================================================
echo "============================================"
echo "  1/3 生成路网"
echo "============================================"
./src/task_planner/roadmap_generator \
    --map data/maps/binary_map_scaled.png \
    --usvs src/task_planner/config/usvs.txt \
    --tasks src/task_planner/config/tasks.txt \
    --gas src/task_planner/config/gas_stations.txt \
    --output src/task_planner/output/road_network.json

# ============================================================
#  2/3 路网可视化 + 分配路线图
# ============================================================
echo ""
echo "============================================"
echo "  2/3 路网图 + 分配路线图"
echo "============================================"
$PY src/task_planner/scripts/gen_roadmap_png.py
$PY src/task_planner/scripts/gen_allocation_map.py

# ============================================================
#  3/3 Greedy vs Graph-ALNS 公平对比
# ============================================================
echo ""
echo "============================================"
echo "  3/3 Greedy vs Graph-ALNS (${N_SHIPS}船×${N_TASKS}任务)"
echo "============================================"
$PY src/task_planner/scripts/compare_greedy.py

echo ""
echo "============================================"
echo "  完成!"
echo "  output/road_network.json       — 路网数据"
echo "  output/road_network_on_map.png — 路网可视化"
echo "  output/allocation_routes.png   — 分配路线图"
echo "============================================"
